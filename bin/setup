#!/bin/sh

# Dotfiles setup orchestrator (macOS + Linux).
#
# Responsibilities:
#   1. Ensure the repo is cloned at ~/dotfiles.
#   2. Ensure GNU Stow is installed.
#   3. Symlink the shared `common` package into $HOME with Stow.
#   4. Detect the OS, symlink the matching package (`macos`/`linux`) and source
#      its OS-specific setup script.
#   5. Run the shared post-install steps (bin/post-install).
#
# Safe to re-run.

fancy_echo() {
  # shellcheck disable=SC2059
  printf "\\n$1\\n"
}

# Add a failed message if setup fails.
# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && fancy_echo "Setup failed!" >&2; exit $ret' EXIT

# Exit immediately if a command exits with a non-zero status.
set -e

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
DOTFILES_REPO="${DOTFILES_REPO:-https://github.com/AlessioRocco/dotfiles}"

# 1. Clone the repo if it is not already present.
if [ ! -d "$DOTFILES_DIR" ]; then
  fancy_echo "Cloning dotfiles into $DOTFILES_DIR ..."
  git clone "$DOTFILES_REPO" "$DOTFILES_DIR"
fi

OS="$(uname -s)"

# 2. Ensure GNU Stow is available (needed before we can stow anything).
ensure_stow() {
  if command -v stow >/dev/null 2>&1; then
    return
  fi

  fancy_echo "Installing GNU Stow ..."
  case "$OS" in
  Darwin)
    if [ -x /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    if ! command -v brew >/dev/null 2>&1; then
      fancy_echo "Installing Homebrew ..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
      [ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    brew install stow
    ;;
  Linux)
    if command -v apt-get >/dev/null 2>&1; then
      sudo apt-get update && sudo apt-get install -y stow
    elif command -v dnf >/dev/null 2>&1; then
      sudo dnf install -y stow
    elif command -v pacman >/dev/null 2>&1; then
      sudo pacman -S --noconfirm stow
    else
      fancy_echo "Could not find a supported package manager to install stow." >&2
      exit 1
    fi
    ;;
  *)
    fancy_echo "Unsupported OS: $OS" >&2
    exit 1
    ;;
  esac
}

ensure_stow

# 3. Stow the shared package.
fancy_echo "Stowing 'common' ..."
stow --dir="$DOTFILES_DIR" --target="$HOME" --no-folding --restow common

# 4. Stow the OS-specific package and run its setup script.
#    The OS script installs packages (Homebrew bundle, apt, etc.), so it runs
#    before the shared steps below that depend on those tools. It is sourced
#    (not executed) so any environment it sets up (e.g. `brew shellenv`)
#    persists for the shared steps.
case "$OS" in
Darwin)
  fancy_echo "Stowing 'macos' ..."
  stow --dir="$DOTFILES_DIR" --target="$HOME" --no-folding --restow macos
  . "$DOTFILES_DIR/macos/bin/setup"
  ;;
Linux)
  fancy_echo "Stowing 'linux' ..."
  stow --dir="$DOTFILES_DIR" --target="$HOME" --no-folding --restow linux
  . "$DOTFILES_DIR/linux/bin/setup"
  ;;
*)
  fancy_echo "Unsupported OS: $OS" >&2
  exit 1
  ;;
esac

# 5. Shared post-install steps.
fancy_echo "Running post-install steps ..."
. "$DOTFILES_DIR/bin/post-install"

fancy_echo 'Setup completed!'
