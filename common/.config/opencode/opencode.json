{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "bash": {
      "*": "ask",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "bin/rails *": "allow",
      "bin/rake *": "allow",
      "bin/rspec *": "allow",
      "bundle *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "find *": "allow",
      "gem *": "allow",
      "gh *": "allow",
      "git *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "rails *": "allow",
      "rake *": "allow",
      "rg *": "allow",
      "rspec *": "allow",
      "sed *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "rm *": "ask",
    },
    "doom_loop": "deny",
    "external_directory": {
      "~/.local/share/mise/installs/ruby/**": "allow",
      "~/.local/share/nvim/**": "allow",
      "~/.local/share/nvim-lazyvim/**": "allow"
    },
    "edit": {
      "~/.local/share/mise/installs/ruby/**": "deny",
      "~/.local/share/nvim/**": "deny",
      "~/.local/share/nvim-lazyvim/**": "deny"
    }
  },
}
